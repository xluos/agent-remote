{
  "name": "agents-remote",
  "version": "1.0.11",
  "description": "双端共享 Claude / Codex CLI 工具",
  "bin": {
    "agents-remote": "bin/agents-remote",
    "agent-remote": "bin/agents-remote",
    "agt": "bin/agents-remote",
    "cla": "bin/cla",
    "cl": "bin/cl",
    "cx": "bin/cx",
    "cdx": "bin/cdx"
  },
  "scripts": {
    "preinstall": "bash scripts/preinstall.sh",
    "postinstall": "bash scripts/postinstall.sh"
  },
  "files": [
    "bin/",
    "scripts/*.sh",
    "scripts/*.py",
    "init.sh",
    "agent_remote.py",
    "server/*.py",
    "server/parsers/*.py",
    "client/*.py",
    "utils/*.py",
    "lark_client/__init__.py",
    "lark_client/*.py",
    "stats/__init__.py",
    "stats/*.py",
    "pyproject.toml",
    ".env.example"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xluos/agents-remote.git"
  },
  "homepage": "https://github.com/xluos/agents-remote#readme",
  "bugs": {
    "url": "https://github.com/xluos/agents-remote/issues"
  },
  "keywords": [
    "claude",
    "cli",
    "terminal",
    "pty",
    "lark"
  ],
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
