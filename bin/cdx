#!/bin/bash
# cdx — agent-remote 启动 Codex，默认权限确认
# 参数解析同 cla，详见 cla 注释

SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && cd .. && pwd)"

source "$SCRIPT_DIR/scripts/ensure-uv.sh"

NAME=""
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--name) NAME="$2"; shift 2 ;;
        *) ARGS+=("$1"); shift ;;
    esac
done
set -- "${ARGS[@]}"

if [[ -z "$NAME" && $# -gt 0 && "$1" != -* ]]; then
    NAME="$1"; shift
fi
[[ "$1" == "--" ]] && shift
[[ -z "$NAME" ]] && NAME="${PWD}_$(date +%m%d_%H%M%S)"

uv run --project "$SCRIPT_DIR" python3 "$SCRIPT_DIR/agent_remote.py" lark start
uv run --project "$SCRIPT_DIR" python3 "$SCRIPT_DIR/agent_remote.py" start "$NAME" --cli codex -- "$@"
